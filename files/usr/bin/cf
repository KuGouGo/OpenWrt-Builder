#!/bin/sh

set -eu

env_file='/etc/openwrt-builder/cloudflare.env'

if [ ! -r "$env_file" ]; then
    echo "Missing ${env_file}" >&2
    exit 1
fi

# shellcheck source=/etc/openwrt-builder/cloudflare.env
. "$env_file"

: "${CF_TOKEN:?Missing CF_TOKEN in /etc/openwrt-builder/cloudflare.env}"

host="${ZASHBOARD_HOST:-zashboard.kugougou.store}"
record_name="${ZASHBOARD_RECORD_NAME:-zashboard}"
zone_name="${ZASHBOARD_ZONE_NAME:-${host#*.}}"
domain_tag="${record_name}@${zone_name}"
acme_email="${ACME_EMAIL:-}"
v4_interval="${DDNS_V4_INTERVAL:-5}"
v6_interval="${DDNS_V6_INTERVAL:-10}"

uci -q batch <<EOF
set ddns.cloudflare_ipv4=service
set ddns.cloudflare_ipv4.enabled='1'
set ddns.cloudflare_ipv4.service_name='cloudflare.com-v4'
set ddns.cloudflare_ipv4.lookup_host='${host}'
set ddns.cloudflare_ipv4.domain='${domain_tag}'
set ddns.cloudflare_ipv4.username='Bearer'
set ddns.cloudflare_ipv4.password='${CF_TOKEN}'
set ddns.cloudflare_ipv4.use_ipv6='0'
set ddns.cloudflare_ipv4.use_https='1'
set ddns.cloudflare_ipv4.cacert='/etc/ssl/certs'
set ddns.cloudflare_ipv4.interface='wan'
set ddns.cloudflare_ipv4.ip_source='network'
set ddns.cloudflare_ipv4.ip_network='wan'
set ddns.cloudflare_ipv4.use_api_check='1'
set ddns.cloudflare_ipv4.use_syslog='2'
set ddns.cloudflare_ipv4.check_interval='${v4_interval}'

set ddns.cloudflare_ipv6=service
set ddns.cloudflare_ipv6.enabled='1'
set ddns.cloudflare_ipv6.service_name='cloudflare.com-v4'
set ddns.cloudflare_ipv6.lookup_host='${host}'
set ddns.cloudflare_ipv6.domain='${domain_tag}'
set ddns.cloudflare_ipv6.username='Bearer'
set ddns.cloudflare_ipv6.password='${CF_TOKEN}'
set ddns.cloudflare_ipv6.use_ipv6='1'
set ddns.cloudflare_ipv6.use_https='1'
set ddns.cloudflare_ipv6.cacert='/etc/ssl/certs'
set ddns.cloudflare_ipv6.interface='wan6'
set ddns.cloudflare_ipv6.ip_source='network'
set ddns.cloudflare_ipv6.ip_network='wan6'
set ddns.cloudflare_ipv6.use_api_check='1'
set ddns.cloudflare_ipv6.use_syslog='2'
set ddns.cloudflare_ipv6.check_interval='${v6_interval}'

set acme.zashboard=cert
set acme.zashboard.enabled='1'
set acme.zashboard.validation_method='dns'
set acme.zashboard.dns='dns_cf'
set acme.zashboard.domains='${host}'
set acme.zashboard.key_type='rsa2048'
set acme.zashboard.dns_wait='30'
set acme.zashboard.credentials='CF_Token="${CF_TOKEN}"'
EOF

if [ -n "$acme_email" ] && uci -q get acme.@acme[0] >/dev/null 2>&1; then
    uci -q set acme.@acme[0].account_email="$acme_email"
fi

uci commit ddns
uci commit acme

chmod 600 /etc/config/ddns /etc/config/acme 2>/dev/null || true

/usr/bin/zb >/dev/null 2>&1 || true

echo "Cloudflare DDNS/ACME configuration applied for ${host}"

exit 0
