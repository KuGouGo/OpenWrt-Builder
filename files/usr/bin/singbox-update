#!/bin/sh

set -eu
export PATH=/usr/sbin:/usr/bin:/sbin:/bin
trap '' HUP PIPE
umask 077

SINGBOX_BIN="/usr/bin/sing-box"
INITD="/etc/init.d/sing-box"
CONFIG_DIR="/etc/sing-box"
CONFIG_FILE="${CONFIG_DIR}/config.json"
CONFIG_URL="PLEASE_SET_SINGBOX_CONFIG_URL"

LOG_FILE="/tmp/singbox-update.log"
LOCK_DIR="/tmp/.singbox-update.lock"
TEMP_CONFIG="/tmp/singbox_config.json.tmp"
LOCK_ACQUIRED=0

C_RESET='\033[0m'
C_RED='\033[31m'
C_GREEN='\033[32m'
C_YELLOW='\033[33m'
C_CYAN='\033[36m'
C_GREY='\033[90m'

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }
log() { printf '%b\n' "${C_GREY}[$(timestamp)]${C_RESET} $*" | tee -a "$LOG_FILE" >/dev/null 2>&1 || true; }
info() { log "${C_CYAN}[信息]${C_RESET} $*"; }
success() { log "${C_GREEN}[成功]${C_RESET} $*"; }
warn() { log "${C_YELLOW}[警告]${C_RESET} $*"; }
error() { log "${C_RED}[错误]${C_RESET} $*"; exit 1; }

cleanup() {
    [ "$LOCK_ACQUIRED" -eq 1 ] && rm -rf "$LOCK_DIR" 2>/dev/null || true
    rm -f "$TEMP_CONFIG" 2>/dev/null || true
}
trap cleanup INT TERM EXIT

acquire_lock() {
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        LOCK_ACQUIRED=1
        return
    fi

    last_lock="$(stat -c %Y "$LOCK_DIR" 2>/dev/null || echo 0)"
    now="$(date +%s)"
    if [ $((now - last_lock)) -gt 900 ]; then
        warn "检测到过期锁，正在清理后重试..."
        rm -rf "$LOCK_DIR"
        if mkdir "$LOCK_DIR" 2>/dev/null; then
            LOCK_ACQUIRED=1
            return
        fi
        error "清理过期锁后仍无法获取锁"
    fi

    error "脚本已在运行中，请稍后再试"
}

check_deps() {
    command -v md5sum >/dev/null 2>&1 || error "缺少依赖命令: md5sum"
    command -v awk >/dev/null 2>&1 || error "缺少依赖命令: awk"

    if command -v curl >/dev/null 2>&1; then
        DOWNLOADER="curl"
    elif command -v wget >/dev/null 2>&1; then
        DOWNLOADER="wget"
    else
        error "缺少下载工具，请安装 curl 或 wget-ssl"
    fi
}

check_singbox() {
    [ -x "$SINGBOX_BIN" ] || error "sing-box 未安装或不可执行: $SINGBOX_BIN"
    [ -x "$INITD" ] || error "未找到 sing-box 服务脚本: $INITD"
    [ "$CONFIG_URL" != "PLEASE_SET_SINGBOX_CONFIG_URL" ] || error "请先编辑脚本中的 CONFIG_URL"
}

download_config() {
    info "正在下载配置文件..."

    if [ "$DOWNLOADER" = "curl" ]; then
        curl -fsSL --connect-timeout 15 --max-time 60 -o "$TEMP_CONFIG" "$CONFIG_URL" || return 1
    else
        wget -q --timeout=60 -O "$TEMP_CONFIG" "$CONFIG_URL" || return 1
    fi
}

validate_config() {
    info "正在验证配置文件..."
    if "$SINGBOX_BIN" check -c "$TEMP_CONFIG" >/dev/null 2>&1; then
        return 0
    fi

    warn "配置文件校验失败，请检查下发内容或在设备上手动运行 'sing-box check -c $TEMP_CONFIG'"
    rm -f "$TEMP_CONFIG"
    return 1
}

update_config() {
    download_config || {
        warn "配置文件下载失败"
        return 1
    }

    validate_config || return 1

    local_md5=""
    remote_md5="$(md5sum "$TEMP_CONFIG" | awk '{print $1}')"
    [ -f "$CONFIG_FILE" ] && local_md5="$(md5sum "$CONFIG_FILE" | awk '{print $1}')"

    if [ "$local_md5" = "$remote_md5" ]; then
        rm -f "$TEMP_CONFIG"
        success "配置文件无变化，无需更新"
        return 1
    fi

    info "检测到配置变更，正在更新..."
    mkdir -p "$CONFIG_DIR"
    mv -f "$TEMP_CONFIG" "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    success "配置文件已更新"
    return 0
}

service_enabled() {
    "$INITD" enabled >/dev/null 2>&1
}

restart_service() {
    info "正在通过 procd 重启 sing-box 服务..."
    "$INITD" restart >/dev/null 2>&1 || error "服务重启命令执行失败"
    sleep 3

    if pidof sing-box >/dev/null 2>&1; then
        success "服务重启成功"
        return
    fi

    error "服务启动失败，请使用 'logread | grep sing-box' 排查"
}

main() {
    [ "$(id -u)" -eq 0 ] || error "需要 root 权限运行"

    > "$LOG_FILE"

    acquire_lock
    check_deps
    check_singbox

    info "================================"
    info "sing-box OpenWrt 配置更新工具"
    info "================================"

    need_restart=0
    if update_config; then
        need_restart=1
    fi

    if service_enabled; then
        if [ "$need_restart" -eq 1 ] || ! pidof sing-box >/dev/null 2>&1; then
            restart_service
        else
            success "服务运行正常"
        fi
    else
        info "sing-box 当前为禁用状态，已跳过启动/重启"
    fi

    info "================================"
    success "任务完成"
    info "================================"
}

main "$@"
