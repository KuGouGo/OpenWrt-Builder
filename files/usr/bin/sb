#!/bin/sh

set -eu
export PATH=/usr/sbin:/usr/bin:/sbin:/bin
trap '' HUP PIPE

SINGBOX_BIN="/usr/bin/sing-box"
INITD="/etc/init.d/sing-box"
CONFIG_DIR="/etc/sing-box"
CONFIG_FILE="${CONFIG_DIR}/config.json"
SETTINGS_FILE="/etc/sb.conf"

LOG_FILE="/tmp/sb.log"
LOCK_DIR="/tmp/.sb.lock"
LOCK_PID_FILE="${LOCK_DIR}/pid"
TEMP_CONFIG="/tmp/sing-box-config.json.tmp"
TEMP_PACKAGE=""
TEMP_CONFIG_BACKUP=""
LOCK_ACQUIRED=0
CONFIG_HAD_PREVIOUS=0

action="all"
version=""
config_url=""
release_channel=""
show_full_url=0
core_changed=0
config_changed=0
config_rolled_back=0

C_RESET=''
C_BOLD=''
C_DIM=''
C_RED=''
C_GREEN=''
C_YELLOW=''
C_CYAN=''
C_GREY=''

setup_colors() {
    if [ -t 1 ] && [ "${TERM:-}" != "dumb" ]; then
        C_RESET="$(printf '\033[0m')"
        C_BOLD="$(printf '\033[1m')"
        C_DIM="$(printf '\033[2m')"
        C_RED="$(printf '\033[31m')"
        C_GREEN="$(printf '\033[32m')"
        C_YELLOW="$(printf '\033[33m')"
        C_CYAN="$(printf '\033[36m')"
        C_GREY="$(printf '\033[90m')"
    fi
}

timestamp() {
    date '+%Y-%m-%d %H:%M:%S'
}

log() {
    printf '[%s] %s\n' "$(timestamp)" "$*" | tee -a "$LOG_FILE"
}

info() {
    log "INFO  $*"
}

warn() {
    log "WARN  $*"
}

fail() {
    log "ERROR $*"
    exit 1
}

require_root() {
    [ "$(id -u)" -eq 0 ] || fail "root is required"
}

ensure_root_for_settings() {
    if [ "$(id -u)" -ne 0 ]; then
        warn "root is required to change saved settings"
        pause_line
        return 1
    fi
    return 0
}

paint() {
    color="$1"
    shift
    printf '%s%s%s' "$color" "$*" "$C_RESET"
}

hr() {
    printf '%s\n' '------------------------------------------------------------'
}

ui_title() {
    printf '\n'
    hr
    printf '%s%s%s\n' "$C_BOLD" "$1" "$C_RESET"
    hr
}

ui_row() {
    key="$1"
    value="$2"
    printf '  %-12s %s\n' "$key" "$value"
}

service_badge() {
    case "$1" in
        running)
            paint "$C_GREEN" "running"
            ;;
        stopped)
            paint "$C_YELLOW" "stopped"
            ;;
        *)
            printf '%s' "$1"
            ;;
    esac
}

channel_badge() {
    case "$1" in
        stable)
            paint "$C_GREEN" "stable"
            ;;
        beta)
            paint "$C_YELLOW" "beta"
            ;;
        *)
            printf '%s' "$1"
            ;;
    esac
}

config_badge() {
    if [ -n "$1" ]; then
        paint "$C_CYAN" "$(mask_value "$1")"
    else
        paint "$C_RED" "unset"
    fi
}

usage() {
    cat <<'EOF'
Usage:
  sb
  sb [all|core|config] [--version VERSION] [--config-url URL] [--stable|--beta]
  sb set-config-url [URL]
  sb show-config-url [--full]
  sb set-channel [stable|beta]
  sb show-channel

Examples:
  sb
  sb core --stable
  sb core --version 1.12.10
  sb config --config-url https://example.com/config.json
  sb set-config-url https://example.com/config.json
  sb set-channel beta
EOF
}

cleanup() {
    [ "$LOCK_ACQUIRED" -eq 1 ] && rm -rf "$LOCK_DIR" 2>/dev/null || true
    rm -f "$TEMP_CONFIG" 2>/dev/null || true
    [ -n "$TEMP_PACKAGE" ] && rm -f "$TEMP_PACKAGE" 2>/dev/null || true
    [ -n "$TEMP_CONFIG_BACKUP" ] && rm -f "$TEMP_CONFIG_BACKUP" 2>/dev/null || true
}
trap cleanup INT TERM EXIT

is_interactive_terminal() {
    [ -t 0 ] && [ -t 1 ]
}

read_setting() {
    key="$1"
    [ -f "$SETTINGS_FILE" ] || return 0
    awk -F= -v target="$key" '
        $1 == target {
            sub(/^[^=]*=/, "", $0)
            gsub(/\r$/, "", $0)
            print $0
            exit
        }
    ' "$SETTINGS_FILE"
}

saved_config_url() {
    read_setting CONFIG_URL
}

saved_release_channel() {
    saved_channel="$(read_setting RELEASE_CHANNEL)"
    if [ -n "$saved_channel" ]; then
        printf '%s\n' "$saved_channel"
    else
        printf 'stable\n'
    fi
}

write_settings() {
    settings_config_url="$1"
    settings_release_channel="$2"
    mkdir -p /etc
    umask 077
    : > "$SETTINGS_FILE"
    [ -n "$settings_config_url" ] && printf 'CONFIG_URL=%s\n' "$settings_config_url" >> "$SETTINGS_FILE"
    printf 'RELEASE_CHANNEL=%s\n' "$settings_release_channel" >> "$SETTINGS_FILE"
}

mask_value() {
    value="$1"
    printf '%s\n' "$value" | awk '
        {
            len = length($0)
            if (len <= 20) {
                print $0
            } else {
                print substr($0, 1, 12) "..." substr($0, len - 7, 8)
            }
        }
    '
}

is_valid_config_url() {
    case "$1" in
        http://*|https://*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

validate_config_url() {
    is_valid_config_url "$1" || fail "config url must start with http:// or https://"
}

is_valid_release_channel() {
    case "$1" in
        stable|beta)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

validate_release_channel() {
    is_valid_release_channel "$1" || fail "release channel must be stable or beta"
}

save_config_url() {
    [ $# -gt 0 ] || fail "missing config url"
    validate_config_url "$1"
    config_url="$1"
    release_channel="$(saved_release_channel)"
    validate_release_channel "$release_channel"
    write_settings "$config_url" "$release_channel"
    info "config url saved to $SETTINGS_FILE"
}

save_release_channel() {
    [ $# -gt 0 ] || fail "missing release channel"
    validate_release_channel "$1"
    release_channel="$1"
    config_url="$(saved_config_url)"
    write_settings "$config_url" "$release_channel"
    info "release channel saved to $SETTINGS_FILE"
}

show_config_url() {
    config_url="$(saved_config_url)"
    [ -n "$config_url" ] || fail "config url is not set"
    if [ "$show_full_url" -eq 1 ]; then
        printf '%s\n' "$config_url"
    else
        mask_value "$config_url"
    fi
}

show_release_channel() {
    release_channel="$(saved_release_channel)"
    validate_release_channel "$release_channel"
    printf '%s\n' "$release_channel"
}

current_core_version() {
    if [ -x "$SINGBOX_BIN" ]; then
        "$SINGBOX_BIN" version 2>/dev/null | awk 'NR==1 { print $3; exit }'
    else
        printf 'not-installed\n'
    fi
}

service_status() {
    if service_running; then
        printf 'running\n'
    else
        printf 'stopped\n'
    fi
}

service_running() {
    pidof sing-box >/dev/null 2>&1
}

acquire_lock() {
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        printf '%s\n' "$$" > "$LOCK_PID_FILE"
        LOCK_ACQUIRED=1
        return 0
    fi

    existing_pid=""
    if [ -f "$LOCK_PID_FILE" ]; then
        existing_pid="$(sed -n '1p' "$LOCK_PID_FILE" 2>/dev/null || true)"
    fi

    if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
        fail "another update task is already running (pid: $existing_pid)"
    fi

    warn "stale lock found, cleaning it"
    rm -rf "$LOCK_DIR" 2>/dev/null || fail "failed to remove stale lock"
    mkdir "$LOCK_DIR" 2>/dev/null || fail "failed to acquire lock"
    printf '%s\n' "$$" > "$LOCK_PID_FILE"
    LOCK_ACQUIRED=1
}

check_deps() {
    command -v curl >/dev/null 2>&1 || fail "curl is required"
    command -v apk >/dev/null 2>&1 || fail "apk is required"
    command -v awk >/dev/null 2>&1 || fail "awk is required"
    command -v jq >/dev/null 2>&1 || fail "jq is required"
    command -v md5sum >/dev/null 2>&1 || fail "md5sum is required"
    command -v sha256sum >/dev/null 2>&1 || fail "sha256sum is required"
    [ -x "$SINGBOX_BIN" ] || fail "sing-box is not installed: $SINGBOX_BIN"
}

prompt_line() {
    prompt="$1"
    printf '%s' "$prompt" >&2
    IFS= read -r reply || true
    printf '%s\n' "$reply"
}

prompt_with_default() {
    label="$1"
    default_value="$2"
    if [ -n "$default_value" ]; then
        prompt="${label} [${default_value}]: "
    else
        prompt="${label}: "
    fi
    reply="$(prompt_line "$prompt")"
    if [ -n "$reply" ]; then
        printf '%s\n' "$reply"
    else
        printf '%s\n' "$default_value"
    fi
}

confirm_yes() {
    prompt="$1"
    default_answer="${2:-y}"

    case "$default_answer" in
        y|Y)
            answer="$(prompt_line "${prompt} [Y/n]: ")"
            [ -n "$answer" ] || answer="y"
            ;;
        *)
            answer="$(prompt_line "${prompt} [y/N]: ")"
            [ -n "$answer" ] || answer="n"
            ;;
    esac

    case "$answer" in
        y|Y|yes|YES)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

pause_line() {
    if is_interactive_terminal; then
        prompt_line 'Press Enter to continue...' >/dev/null
    fi
}

prepare_config_url_interactive() {
    if [ -n "$config_url" ]; then
        return 0
    fi

    config_url="$(saved_config_url)"
    if [ -n "$config_url" ]; then
        return 0
    fi

    warn "config url is not set"
    temp_url="$(prompt_line 'Enter a temporary config url, or leave empty to cancel: ')"
    if [ -z "$temp_url" ]; then
        warn "config update cancelled"
        pause_line
        return 1
    fi

    if ! is_valid_config_url "$temp_url"; then
        warn "invalid config url"
        pause_line
        return 1
    fi

    config_url="$temp_url"
    if confirm_yes "Save this url to ${SETTINGS_FILE}?" "n"; then
        ensure_root_for_settings || return 0
        save_config_url "$config_url"
    fi
    return 0
}

show_state_panel() {
    menu_config_url="$(saved_config_url)"
    menu_release_channel="$(saved_release_channel)"

    ui_title "sb | sing-box helper"
    ui_row "Core" "$(current_core_version)"
    ui_row "Service" "$(service_badge "$(service_status)")"
    ui_row "Channel" "$(channel_badge "$menu_release_channel")"
    ui_row "Config" "$(config_badge "$menu_config_url")"
    ui_row "Log" "$LOG_FILE"
}

show_plan_panel() {
    ui_title "Planned action"
    ui_row "Action" "$action"
    case "$action" in
        all|core)
            if [ -n "$version" ]; then
                ui_row "Version" "$version"
            else
                ui_row "Version" "latest from ${release_channel}"
            fi
            ui_row "Channel" "$(channel_badge "$release_channel")"
            ;;
    esac
    case "$action" in
        all|config)
            ui_row "Config" "$(config_badge "$config_url")"
            ;;
    esac
}

change_badge() {
    case "$1" in
        yes)
            paint "$C_GREEN" "updated"
            ;;
        no)
            paint "$C_DIM" "unchanged"
            ;;
        rolled_back)
            paint "$C_YELLOW" "rolled back"
            ;;
        *)
            printf '%s' "$1"
            ;;
    esac
}

show_result_panel() {
    result_config_url="$config_url"
    [ -n "$result_config_url" ] || result_config_url="$(saved_config_url)"
    result_channel="$(saved_release_channel)"

    ui_title "Completed"
    ui_row "Action" "$action"
    ui_row "Core" "$(current_core_version)"
    ui_row "Service" "$(service_badge "$(service_status)")"
    ui_row "Channel" "$(channel_badge "$result_channel")"
    ui_row "Config" "$(config_badge "$result_config_url")"
    ui_row "Core diff" "$(change_badge "$1")"
    ui_row "Config diff" "$(change_badge "$2")"
}

interactive_set_url() {
    ensure_root_for_settings || return 0
    temp_url="$(prompt_line 'New config url, empty to cancel: ')"
    if [ -z "$temp_url" ]; then
        warn "url not changed"
        pause_line
        return 0
    fi
    if ! is_valid_config_url "$temp_url"; then
        warn "config url must start with http:// or https://"
        pause_line
        return 0
    fi
    save_config_url "$temp_url"
    pause_line
}

interactive_show_url() {
    menu_config_url="$(saved_config_url)"
    if [ -z "$menu_config_url" ]; then
        warn "config url is not set"
        pause_line
        return 0
    fi

    ui_title "Config url"
    ui_row "Masked" "$(mask_value "$menu_config_url")"
    if confirm_yes "Show full url?" "n"; then
        ui_row "Full" "$menu_config_url"
    fi
    pause_line
}

interactive_set_channel() {
    ensure_root_for_settings || return 0
    current_channel="$(saved_release_channel)"
    temp_channel="$(prompt_with_default 'Release channel (stable/beta)' "$current_channel")"
    if ! is_valid_release_channel "$temp_channel"; then
        warn "release channel must be stable or beta"
        pause_line
        return 0
    fi
    save_release_channel "$temp_channel"
    pause_line
}

prepare_interactive_core_settings() {
    version="$(prompt_with_default 'Version (empty = latest)' '')"
    release_channel="$(prompt_with_default 'Release channel' "$release_channel")"
    if ! is_valid_release_channel "$release_channel"; then
        warn "release channel must be stable or beta"
        pause_line
        return 1
    fi
    return 0
}

interactive_menu() {
    while true; do
        menu_release_channel="$(saved_release_channel)"
        release_channel="$menu_release_channel"
        config_url=""
        version=""

        show_state_panel
        printf '\n'
        printf '  1. Update core and config\n'
        printf '  2. Update core only\n'
        printf '  3. Update config only\n'
        printf '  4. Set config url\n'
        printf '  5. Show config url\n'
        printf '  6. Change release channel\n'
        printf '  0. Exit\n'
        printf '\n'

        choice="$(prompt_with_default 'Select action' '1')"

        case "$choice" in
            1|all)
                action="all"
                prepare_interactive_core_settings || continue
                prepare_config_url_interactive || continue
                show_plan_panel
                if confirm_yes "Run now?" "y"; then
                    break
                fi
                ;;
            2|core)
                action="core"
                prepare_interactive_core_settings || continue
                show_plan_panel
                if confirm_yes "Run now?" "y"; then
                    break
                fi
                ;;
            3|config)
                action="config"
                temp_url="$(prompt_with_default 'Config url (empty = saved)' '')"
                [ -n "$temp_url" ] && config_url="$temp_url"
                if [ -n "$config_url" ] && ! is_valid_config_url "$config_url"; then
                    warn "config url must start with http:// or https://"
                    pause_line
                    continue
                fi
                prepare_config_url_interactive || continue
                show_plan_panel
                if confirm_yes "Run now?" "y"; then
                    break
                fi
                ;;
            4|set-url)
                interactive_set_url
                ;;
            5|show-url)
                interactive_show_url
                ;;
            6|channel)
                interactive_set_channel
                ;;
            0|exit|quit)
                exit 0
                ;;
            *)
                warn "invalid choice: $choice"
                pause_line
                ;;
        esac
    done
}

parse_args() {
    if [ $# -eq 0 ]; then
        if is_interactive_terminal; then
            action="interactive"
        else
            action="all"
        fi
        return 0
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            all|core|config|show-config-url|show-channel|interactive)
                action="$1"
                shift
                ;;
            set-config-url)
                action="$1"
                shift
                if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
                    config_url="$1"
                    shift
                fi
                ;;
            set-channel)
                action="$1"
                shift
                if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
                    release_channel="$1"
                    shift
                fi
                ;;
            --version)
                shift
                [ $# -gt 0 ] || fail "missing version value"
                version="$1"
                shift
                ;;
            --stable)
                release_channel="stable"
                shift
                ;;
            --beta)
                release_channel="beta"
                shift
                ;;
            --config-url)
                shift
                [ $# -gt 0 ] || fail "missing config url"
                config_url="$1"
                shift
                ;;
            --full)
                show_full_url=1
                shift
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                usage >&2
                fail "unknown argument: $1"
                ;;
        esac
    done
}

detect_arch() {
    arch=""
    if [ -f /etc/os-release ]; then
        # shellcheck source=/etc/os-release
        . /etc/os-release
        arch="${OPENWRT_ARCH:-}"
    fi
    if [ -z "$arch" ]; then
        arch="$(apk --print-arch 2>/dev/null || true)"
    fi
    [ -n "$arch" ] || fail "failed to detect OpenWrt architecture"
    printf '%s\n' "$arch"
}

resolve_version() {
    release_json="$(resolve_release_json)"
    latest_version="$(printf '%s\n' "$release_json" | jq -r '.tag_name' | sed 's/^v//')"
    [ -n "$latest_version" ] && [ "$latest_version" != "null" ] || fail "failed to resolve sing-box version"
    printf '%s\n' "$latest_version"
}

resolve_release_json() {
    if [ -n "$version" ]; then
        curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 60 -fsSL \
            "https://api.github.com/repos/SagerNet/sing-box/releases/tags/v${version}"
        return 0
    fi

    [ -n "$release_channel" ] || release_channel="$(saved_release_channel)"
    validate_release_channel "$release_channel"

    if [ "$release_channel" = "stable" ]; then
        curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 60 -fsSL \
            "https://api.github.com/repos/SagerNet/sing-box/releases/latest"
    else
        curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 60 -fsSL \
            "https://api.github.com/repos/SagerNet/sing-box/releases" |
            jq -c 'map(select(.prerelease == true))[0]'
    fi
}

resolve_config_url() {
    if [ -n "$config_url" ]; then
        validate_config_url "$config_url"
        printf '%s\n' "$config_url"
        return 0
    fi

    config_url="$(saved_config_url)"
    [ -n "$config_url" ] || fail "config url is not set, run: sb set-config-url <url>"
    validate_config_url "$config_url"
    printf '%s\n' "$config_url"
}

update_core() {
    arch="$(detect_arch)"
    release_json="$(resolve_release_json)"
    release_tag="$(printf '%s\n' "$release_json" | jq -r '.tag_name')"
    [ -n "$release_tag" ] && [ "$release_tag" != "null" ] || fail "failed to resolve sing-box release tag"
    resolved_version="${release_tag#v}"
    file="sing-box_${resolved_version}_openwrt_${arch}.apk"
    url="https://github.com/SagerNet/sing-box/releases/download/${release_tag}/${file}"
    current_version="$(current_core_version)"

    if [ "$current_version" = "$resolved_version" ]; then
        info "core unchanged"
        return 0
    fi

    expected_sha256="$(printf '%s\n' "$release_json" | jq -r --arg file "$file" '.assets[] | select(.name == $file) | .digest' | head -n 1)"
    [ -n "$expected_sha256" ] && [ "$expected_sha256" != "null" ] || fail "failed to resolve digest for $file"
    expected_sha256="${expected_sha256#sha256:}"

    TEMP_PACKAGE="/tmp/${file}"

    info "downloading $url"
    curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 300 -fL "$url" -o "$TEMP_PACKAGE"

    actual_sha256="$(sha256sum "$TEMP_PACKAGE" | awk '{print $1}')"
    [ "$actual_sha256" = "$expected_sha256" ] || fail "download digest mismatch for $file"

    info "installing $file"
    apk add --allow-untrusted "$TEMP_PACKAGE"
    core_changed=1
    info "sing-box core updated to ${resolved_version}"
}

backup_current_config() {
    TEMP_CONFIG_BACKUP=""
    CONFIG_HAD_PREVIOUS=0

    if [ -f "$CONFIG_FILE" ]; then
        TEMP_CONFIG_BACKUP="/tmp/sing-box-config.json.bak.$$"
        cp -f "$CONFIG_FILE" "$TEMP_CONFIG_BACKUP" || fail "failed to back up existing config"
        chmod 0600 "$TEMP_CONFIG_BACKUP" 2>/dev/null || true
        CONFIG_HAD_PREVIOUS=1
    fi
}

update_config() {
    resolved_config_url="$(resolve_config_url)"
    info "downloading config"
    curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 60 -fsSL "$resolved_config_url" -o "$TEMP_CONFIG" || fail "failed to download config"

    check_output="$("$SINGBOX_BIN" check -c "$TEMP_CONFIG" 2>&1)" || fail "config validation failed: $check_output"

    local_md5=""
    [ -f "$CONFIG_FILE" ] && local_md5="$(md5sum "$CONFIG_FILE" | awk '{print $1}')"
    remote_md5="$(md5sum "$TEMP_CONFIG" | awk '{print $1}')"

    if [ "$local_md5" = "$remote_md5" ]; then
        info "config unchanged"
        rm -f "$TEMP_CONFIG"
        return 0
    fi

    mkdir -p "$CONFIG_DIR"
    backup_current_config
    mv -f "$TEMP_CONFIG" "$CONFIG_FILE"
    chmod 0644 "$CONFIG_FILE"
    config_changed=1
    info "config updated"
}

rollback_config_update() {
    if [ "$CONFIG_HAD_PREVIOUS" -eq 1 ] && [ -n "$TEMP_CONFIG_BACKUP" ] && [ -f "$TEMP_CONFIG_BACKUP" ]; then
        warn "service restart failed, restoring previous sing-box config"
        cp -f "$TEMP_CONFIG_BACKUP" "$CONFIG_FILE" || fail "failed to restore previous config"
        chmod 0644 "$CONFIG_FILE"
        config_changed=0
        config_rolled_back=1
        return 0
    fi

    warn "service restart failed and no previous config is available, removing updated config"
    rm -f "$CONFIG_FILE" 2>/dev/null || true
    return 1
}

restart_service_once() {
    [ -x "$INITD" ] || {
        warn "init script not found, skipped service restart"
        return 0
    }

    info "restarting sing-box service"
    "$INITD" restart >/dev/null 2>&1 || return 1
    sleep 3

    service_running
}

restart_service() {
    if restart_service_once; then
        info "sing-box service is running"
        return 0
    fi

    if [ "$config_changed" -eq 1 ]; then
        if rollback_config_update; then
            warn "retrying sing-box with the previous config"
            restart_service_once || fail "failed to restart sing-box after restoring previous config"
            info "sing-box service is running"
            warn "new config was rolled back after restart failure"
            return 0
        fi

        fail "failed to restart sing-box and no previous config was available to restore"
    fi

    fail "failed to restart sing-box"
}

main() {
    setup_colors
    parse_args "$@"

    case "$action" in
        interactive)
            interactive_menu
            ;;
        set-config-url)
            require_root
            if [ -z "$config_url" ] && is_interactive_terminal; then
                config_url="$(prompt_line 'url: ')"
            fi
            save_config_url "$config_url"
            exit 0
            ;;
        show-config-url)
            show_config_url
            exit 0
            ;;
        set-channel)
            require_root
            if [ -z "$release_channel" ] && is_interactive_terminal; then
                release_channel="$(prompt_line 'channel [stable/beta]: ')"
            fi
            save_release_channel "$release_channel"
            exit 0
            ;;
        show-channel)
            show_release_channel
            exit 0
            ;;
    esac

    require_root
    acquire_lock
    check_deps

    case "$action" in
        all|config)
            resolve_config_url >/dev/null
            ;;
    esac

    : > "$LOG_FILE"
    info "action=${action}"

    case "$action" in
        all)
            update_core
            update_config
            ;;
        core)
            update_core
            ;;
        config)
            update_config
            ;;
    esac

    if [ "$core_changed" -eq 1 ] || [ "$config_changed" -eq 1 ]; then
        restart_service
    elif ! pidof sing-box >/dev/null 2>&1; then
        warn "sing-box is not running, trying to start it"
        restart_service
    else
        info "no restart needed"
    fi

    info "done"
    if is_interactive_terminal; then
        core_state="no"
        config_state="no"
        [ "$core_changed" -eq 1 ] && core_state="yes"
        if [ "$config_rolled_back" -eq 1 ]; then
            config_state="rolled_back"
        elif [ "$config_changed" -eq 1 ]; then
            config_state="yes"
        fi
        show_result_panel "$core_state" "$config_state"
    fi
}

main "$@"
