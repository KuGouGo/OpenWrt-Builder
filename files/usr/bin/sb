#!/bin/sh

set -eu
export PATH=/usr/sbin:/usr/bin:/sbin:/bin
trap '' HUP PIPE

SINGBOX_BIN="/usr/bin/sing-box"
SINGBOX_SERVICE="sing-box"
INITD="/etc/init.d/${SINGBOX_SERVICE}"
CONFIG_DIR="/etc/sing-box"
CONFIG_FILE="${CONFIG_DIR}/config.json"
SETTINGS_FILE="/etc/sb.conf"

RUN_DIR="/run/sb"
LOCK_DIR="${RUN_DIR}/lock"
LOG_DIR="/var/log/sb"
LOG_FILE="${LOG_DIR}/sb.log"
CONFIG_SNAPSHOT_DIR="${CONFIG_DIR}/snapshots"

TMP_DIR=""
TEMP_CONFIG=""
CONFIG_ROLLBACK_FILE=""
LOCK_ACQUIRED=0
CONFIG_HAD_PREVIOUS=0

action=""
config_url=""
core_changed=0
config_changed=0
config_rolled_back=0

C_RESET=''
C_BOLD=''
C_DIM=''
C_RED=''
C_GREEN=''
C_YELLOW=''
C_CYAN=''

setup_colors() {
    if [ -t 1 ] && [ "${TERM:-}" != "dumb" ]; then
        C_RESET="$(printf '\033[0m')"
        C_BOLD="$(printf '\033[1m')"
        C_DIM="$(printf '\033[2m')"
        C_RED="$(printf '\033[31m')"
        C_GREEN="$(printf '\033[32m')"
        C_YELLOW="$(printf '\033[33m')"
        C_CYAN="$(printf '\033[36m')"
    fi
}

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }

ensure_runtime_dirs() {
    mkdir -p "$RUN_DIR" "$LOG_DIR" "$CONFIG_SNAPSHOT_DIR"
    touch "$LOG_FILE"
    chmod 640 "$LOG_FILE" 2>/dev/null || true
}

log() {
    if mkdir -p "$LOG_DIR" 2>/dev/null; then
        printf '[%s] %s\n' "$(timestamp)" "$*" | tee -a "$LOG_FILE"
    else
        printf '[%s] %s\n' "$(timestamp)" "$*"
    fi
}

info() { log "INFO  $*"; }
warn() { log "WARN  $*"; }
fail() {
    log "ERROR $*"
    print_recent_log || true
    exit 1
}

paint() {
    local color="$1"
    shift
    printf '%s%s%s' "$color" "$*" "$C_RESET"
}

hr() {
    printf '%s%s%s\n' "$C_DIM" "--------------------------------------------------" "$C_RESET"
}

ui_title() {
    printf '\n'
    hr
    printf '  %s%s%s\n' "${C_BOLD}${C_CYAN}" "$1" "$C_RESET"
    hr
}

ui_row() {
    printf '  %-14s %s\n' "$1" "$2"
}

service_badge() {
    case "$1" in
        running) paint "$C_GREEN" "运行中" ;;
        stopped) paint "$C_YELLOW" "已停止" ;;
        *) printf '%s' "$1" ;;
    esac
}

config_badge() {
    if [ -n "$1" ]; then
        paint "$C_CYAN" "$(mask_value "$1")"
    else
        paint "$C_RED" "未设置"
    fi
}

change_badge() {
    case "$1" in
        yes) paint "$C_GREEN" "已更新" ;;
        no) paint "$C_DIM" "无变化" ;;
        rolled_back) paint "$C_YELLOW" "已回滚" ;;
        *) printf '%s' "$1" ;;
    esac
}

cleanup() {
    [ "$LOCK_ACQUIRED" -eq 1 ] && rm -rf "$LOCK_DIR" 2>/dev/null || true
    [ -n "$TMP_DIR" ] && rm -rf "$TMP_DIR" 2>/dev/null || true
}
trap cleanup INT TERM EXIT

mktemp_dir() {
    TMP_DIR="$(mktemp -d /tmp/sb.XXXXXX)"
    TEMP_CONFIG="${TMP_DIR}/config.json"
}

acquire_lock() {
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        printf '%s\n' "$$" > "${LOCK_DIR}/pid"
        LOCK_ACQUIRED=1
        return 0
    fi

    local existing_pid
    existing_pid="$(sed -n '1p' "${LOCK_DIR}/pid" 2>/dev/null || true)"
    if [ -n "$existing_pid" ] && kill -0 "$existing_pid" 2>/dev/null; then
        fail "Another sb task is already running (pid: $existing_pid)"
    fi

    warn "Stale lock found, removing it."
    rm -rf "$LOCK_DIR"
    mkdir "$LOCK_DIR"
    printf '%s\n' "$$" > "${LOCK_DIR}/pid"
    LOCK_ACQUIRED=1
}

require_root() {
    [ "$(id -u)" -eq 0 ] || fail "root is required for this action"
}

ensure_root_for_settings() {
    if [ "$(id -u)" -ne 0 ]; then
        warn "Root is required to change saved settings."
        pause_line
        return 1
    fi
    return 0
}

is_interactive_terminal() { [ -t 0 ] && [ -t 1 ]; }

prompt_line() {
    printf '%s' "$1" >&2
    local reply
    IFS= read -r reply || true
    printf '%s\n' "$reply"
}

confirm_yes() {
    local answer
    answer="$(prompt_line "$1 [Y/n]: ")"
    [ -z "$answer" ] && answer="y"
    case "$answer" in
        y|Y|yes|YES) return 0 ;;
        *) return 1 ;;
    esac
}

pause_line() {
    if is_interactive_terminal; then
        printf '\n'
        prompt_line "  ${C_DIM}Press Enter to continue...${C_RESET}" >/dev/null
    fi
}

print_recent_log() {
    if command -v logread >/dev/null 2>&1; then
        logread 2>/dev/null | grep -i 'sing.box\|sing-box' | tail -n 20 \
            | tee -a "$LOG_FILE" >/dev/null || true
    fi
}

read_setting() {
    local key="$1"
    [ -f "$SETTINGS_FILE" ] || return 0
    awk -F= -v k="$key" '$1==k{sub(/^[^=]*=/,"",$0);gsub(/\r$/,"",$0);print $0;exit}' \
        "$SETTINGS_FILE"
}

saved_config_url() { read_setting CONFIG_URL; }

write_settings() {
    local settings_config_url="$1"
    : > "$SETTINGS_FILE"
    chmod 600 "$SETTINGS_FILE" 2>/dev/null || true
    if [ -n "$settings_config_url" ]; then
        printf 'CONFIG_URL=%s\n' "$settings_config_url" >> "$SETTINGS_FILE"
    fi
}

mask_value() {
    printf '%s\n' "$1" | awk '{
        len = length($0)
        if (len <= 20) print $0
        else print substr($0, 1, 12) "..." substr($0, len - 7, 8)
    }'
}

is_valid_config_url() {
    case "$1" in
        http://*|https://*) return 0 ;;
        *) return 1 ;;
    esac
}

validate_config_url() {
    is_valid_config_url "$1" || fail "Config URL must start with http:// or https://"
}

save_config_url() {
    [ $# -gt 0 ] || fail "Missing config URL"
    validate_config_url "$1"
    config_url="$1"
    write_settings "$config_url"
    info "Config URL saved."
}

check_deps() {
    command -v curl >/dev/null 2>&1 || fail "curl is required"
    command -v awk >/dev/null 2>&1 || fail "awk is required"
    command -v jq >/dev/null 2>&1 || fail "jq is required"
    command -v sha256sum >/dev/null 2>&1 || fail "sha256sum is required"
    command -v apk >/dev/null 2>&1 || fail "apk is required"
    [ -x "$SINGBOX_BIN" ] || fail "sing-box is not installed: $SINGBOX_BIN"
    [ -x "$INITD" ] || fail "init script not found: $INITD"
}

current_core_version() {
    if [ -x "$SINGBOX_BIN" ]; then
        "$SINGBOX_BIN" version 2>/dev/null | awk 'NR==1{print $3;exit}'
    else
        printf 'not-installed\n'
    fi
}

service_running() {
    if [ ! -x "$INITD" ]; then
        return 1
    fi
    "$INITD" running >/dev/null 2>&1
}

service_status() {
    if service_running; then
        printf 'running\n'
    else
        printf 'stopped\n'
    fi
}

resolve_config_url() {
    if [ -n "$config_url" ]; then
        validate_config_url "$config_url"
        printf '%s\n' "$config_url"
        return 0
    fi

    config_url="$(saved_config_url)"
    [ -n "$config_url" ] || fail "Config URL is not set. Run: sb set-url <url>"
    validate_config_url "$config_url"
    printf '%s\n' "$config_url"
}

hash_file() {
    sha256sum "$1" | awk '{print $1}'
}

backup_current_config() {
    CONFIG_ROLLBACK_FILE=""
    CONFIG_HAD_PREVIOUS=0
    if [ -f "$CONFIG_FILE" ]; then
        CONFIG_ROLLBACK_FILE="${TMP_DIR}/config.rollback.json"
        cp -f "$CONFIG_FILE" "$CONFIG_ROLLBACK_FILE"
        chmod 600 "$CONFIG_ROLLBACK_FILE" 2>/dev/null || true
        CONFIG_HAD_PREVIOUS=1
    fi
}

persist_config_snapshot() {
    if [ "$config_changed" -ne 1 ] || [ ! -f "$CONFIG_FILE" ]; then
        return 0
    fi

    local short_hash snapshot_path
    short_hash="$(hash_file "$CONFIG_FILE" | cut -c1-12)"
    snapshot_path="${CONFIG_SNAPSHOT_DIR}/config-$(date +%Y%m%d-%H%M%S)-${short_hash}.json"
    cp -f "$CONFIG_FILE" "$snapshot_path"
    chmod 600 "$snapshot_path" 2>/dev/null || true

    local old_snapshots
    old_snapshots="$(ls -1t "${CONFIG_SNAPSHOT_DIR}"/config-*.json 2>/dev/null | sed -n '11,$p')"
    if [ -n "$old_snapshots" ]; then
        printf '%s\n' "$old_snapshots" | xargs rm -f
    fi
}

detect_arch() {
    local arch=""
    if [ -f /etc/os-release ]; then
        # shellcheck source=/etc/os-release
        . /etc/os-release
        arch="${OPENWRT_ARCH:-}"
    fi
    if [ -z "$arch" ]; then
        arch="$(apk --print-arch 2>/dev/null || true)"
    fi
    [ -n "$arch" ] || fail "Could not detect OpenWrt architecture"
    printf '%s\n' "$arch"
}

update_core() {
    local arch current_version release_json latest_tag latest_version
    local pkg_file pkg_url expected_digest actual_sha256 pkg_path

    arch="$(detect_arch)"
    current_version="$(current_core_version)"

    info "Querying latest sing-box release from GitHub..."
    release_json="$(curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 60 \
        -fsSL "https://api.github.com/repos/SagerNet/sing-box/releases/latest")" \
        || fail "Failed to query GitHub API"

    latest_tag="$(printf '%s\n' "$release_json" | jq -r '.tag_name')"
    [ -n "$latest_tag" ] && [ "$latest_tag" != "null" ] \
        || fail "Failed to parse latest sing-box release tag"
    latest_version="${latest_tag#v}"

    if [ "$current_version" = "$latest_version" ]; then
        info "Core is already up to date (${current_version})."
        return 0
    fi

    pkg_file="sing-box_${latest_version}_openwrt_${arch}.apk"
    pkg_url="https://github.com/SagerNet/sing-box/releases/download/${latest_tag}/${pkg_file}"

    expected_digest="$(printf '%s\n' "$release_json" \
        | jq -r --arg f "$pkg_file" '.assets[] | select(.name == $f) | .digest' \
        | head -n 1)"
    [ -n "$expected_digest" ] && [ "$expected_digest" != "null" ] \
        || fail "Could not find asset digest for ${pkg_file}"
    expected_digest="${expected_digest#sha256:}"

    info "Updating: ${current_version} → ${latest_version}"
    pkg_path="${TMP_DIR}/${pkg_file}"
    curl --retry 3 --retry-all-errors --connect-timeout 15 --max-time 300 \
        -fL "$pkg_url" -o "$pkg_path" || fail "Failed to download ${pkg_file}"

    actual_sha256="$(hash_file "$pkg_path")"
    [ "$actual_sha256" = "$expected_digest" ] || fail "Digest mismatch for ${pkg_file}"

    info "Installing ${pkg_file}..."
    apk add --no-progress --allow-untrusted "$pkg_path" || fail "Failed to install sing-box"

    core_changed=1
    info "Core updated to ${latest_version}."
}

update_config() {
    local resolved_url local_hash remote_hash check_output

    resolved_url="$(resolve_config_url)"
    info "Downloading configuration..."
    curl --retry 3 --retry-delay 2 --retry-all-errors \
        --connect-timeout 15 --max-time 60 \
        -fsSL "$resolved_url" -o "$TEMP_CONFIG" || fail "Failed to download config"

    [ -s "$TEMP_CONFIG" ] || fail "Downloaded config is empty"

    check_output="$("$SINGBOX_BIN" check -c "$TEMP_CONFIG" 2>&1)" \
        || fail "Config validation failed: $check_output"

    local_hash=""
    [ -f "$CONFIG_FILE" ] && local_hash="$(hash_file "$CONFIG_FILE")"
    remote_hash="$(hash_file "$TEMP_CONFIG")"

    if [ "$local_hash" = "$remote_hash" ]; then
        info "Config is unchanged."
        return 0
    fi

    mkdir -p "$CONFIG_DIR"
    backup_current_config
    cp -f "$TEMP_CONFIG" "$CONFIG_FILE"
    chmod 600 "$CONFIG_FILE"
    config_changed=1
    info "Config updated."
}

rollback_config_update() {
    if [ "$CONFIG_HAD_PREVIOUS" -eq 1 ] && [ -n "$CONFIG_ROLLBACK_FILE" ] \
       && [ -f "$CONFIG_ROLLBACK_FILE" ]; then
        warn "Service restart failed. Restoring previous config..."
        cp -f "$CONFIG_ROLLBACK_FILE" "$CONFIG_FILE" || fail "Failed to restore config"
        chmod 600 "$CONFIG_FILE"
        config_changed=0
        config_rolled_back=1
        return 0
    fi

    warn "No previous config backup. Removing broken config..."
    rm -f "$CONFIG_FILE" 2>/dev/null || true
    return 1
}

wait_for_service() {
    local attempt max_attempts
    max_attempts="${1:-15}"
    attempt=1
    while [ "$attempt" -le "$max_attempts" ]; do
        service_running && return 0
        sleep 1
        attempt=$((attempt + 1))
    done
    return 1
}

restart_service() {
    info "Restarting ${SINGBOX_SERVICE} service..."

    if "$INITD" restart && wait_for_service 15; then
        info "Service is running."
        return 0
    fi

    print_recent_log || true

    if [ "$config_changed" -eq 1 ]; then
        if rollback_config_update; then
            warn "Retrying with the previous config..."
            "$INITD" restart || fail "Failed to restart after restoring previous config"
            wait_for_service 15 || fail "Service did not recover after rollback"
            warn "New config was rolled back because the service failed to restart."
            return 0
        fi
        fail "Failed to restart sing-box and no rollback was available."
    fi

    fail "Failed to restart ${SINGBOX_SERVICE}."
}

show_state_panel() {
    clear
    ui_title "Sing-Box 管理面板"
    ui_row "核心版本" "$(current_core_version)"
    ui_row "服务状态" "$(service_badge "$(service_status)")"
    ui_row "订阅地址" "$(config_badge "$(saved_config_url)")"
    hr
}

show_result_panel() {
    local core_state config_state

    core_state="no"
    config_state="no"
    [ "$core_changed" -eq 1 ] && core_state="yes"
    if [ "$config_rolled_back" -eq 1 ]; then
        config_state="rolled_back"
    elif [ "$config_changed" -eq 1 ]; then
        config_state="yes"
    fi

    ui_title "任务完成"
    ui_row "核心版本" "$(current_core_version)"
    ui_row "服务状态" "$(service_badge "$(service_status)")"
    ui_row "核心更新" "$(change_badge "$core_state")"
    ui_row "配置更新" "$(change_badge "$config_state")"
    hr
}

prepare_config_url_interactive() {
    [ -n "$config_url" ] && return 0

    config_url="$(saved_config_url)"
    [ -n "$config_url" ] && return 0

    printf '\n'
    warn "尚未设置订阅地址。"
    local temp_url
    temp_url="$(prompt_line "  请输入订阅地址: ")"
    if [ -z "$temp_url" ]; then
        warn "已取消。"
        pause_line
        return 1
    fi
    if ! is_valid_config_url "$temp_url"; then
        warn "地址格式不正确，需以 http:// 或 https:// 开头。"
        pause_line
        return 1
    fi

    config_url="$temp_url"
    if confirm_yes "  是否保存为默认订阅地址？"; then
        ensure_root_for_settings || return 0
        save_config_url "$config_url"
    fi
    return 0
}

interactive_set_url() {
    ensure_root_for_settings || return 0
    printf '\n'
    local temp_url
    temp_url="$(prompt_line "  请输入新的订阅地址（留空取消）: ")"
    [ -z "$temp_url" ] && return 0
    if ! is_valid_config_url "$temp_url"; then
        warn "地址必须以 http:// 或 https:// 开头。"
        pause_line
        return 0
    fi
    save_config_url "$temp_url"
    pause_line
}

interactive_show_url() {
    local current_url
    current_url="$(saved_config_url)"
    if [ -z "$current_url" ]; then
        printf '\n'
        warn "尚未设置订阅地址。"
        pause_line
        return 0
    fi
    ui_title "当前订阅地址"
    ui_row "脱敏" "$(mask_value "$current_url")"
    if confirm_yes "  是否显示完整地址？"; then
        ui_row "完整" "$current_url"
    fi
    pause_line
}

interactive_menu() {
    while true; do
        config_url=""
        show_state_panel

        printf "  %s更新操作%s\n" "$C_BOLD" "$C_RESET"
        printf "  ${C_CYAN}[ 1 ]${C_RESET} 更新订阅配置\n"
        printf "  ${C_CYAN}[ 2 ]${C_RESET} 更新内核程序\n"
        printf "  ${C_CYAN}[ 3 ]${C_RESET} 同时更新内核和配置\n"
        printf "  ${C_DIM}------------------------------------------${C_RESET}\n"
        printf "  %s管理操作%s\n" "$C_BOLD" "$C_RESET"
        printf "  ${C_CYAN}[ 4 ]${C_RESET} 设置订阅地址\n"
        printf "  ${C_CYAN}[ 5 ]${C_RESET} 查看订阅地址\n"
        printf "  ${C_CYAN}[ 6 ]${C_RESET} 查看当前状态\n"
        printf "  ${C_RED}[ 0 ]${C_RESET} 退出\n\n"

        case "$(prompt_line "  请选择操作 [0-6]: ")" in
            1) action="config"; prepare_config_url_interactive || continue; break ;;
            2) action="core"; break ;;
            3) action="all"; prepare_config_url_interactive || continue; break ;;
            4) interactive_set_url ;;
            5) interactive_show_url ;;
            6) show_status; pause_line ;;
            0|exit|quit) clear; exit 0 ;;
            *) warn "无效选项，请重新输入。"; sleep 1 ;;
        esac
    done
}

show_status() {
    ui_title "当前状态"
    ui_row "核心版本" "$(current_core_version)"
    ui_row "服务状态" "$(service_badge "$(service_status)")"
    ui_row "订阅地址" "$(config_badge "$(saved_config_url)")"
    ui_row "配置文件" "$CONFIG_FILE"
    ui_row "日志文件" "$LOG_FILE"
    ui_row "快照目录" "$CONFIG_SNAPSHOT_DIR"
    hr
}

show_url_cli() {
    local current_url
    current_url="$(saved_config_url)"
    if [ -z "$current_url" ]; then
        printf '未设置\n'
    else
        printf '%s\n' "$current_url"
    fi
}

show_help() {
    cat <<'EOF'
用法：
  sb
    在终端中打开交互菜单。

  sb all [url]
    同时更新 sing-box 内核和订阅配置。

  sb core
    仅从 GitHub 最新 Release 更新内核。

  sb config [url]
    仅更新订阅配置。

  sb status
    查看当前状态。

  sb show-url
    显示已保存的订阅地址。

  sb set-url <url>
    保存订阅地址。

  sb help
    显示帮助。
EOF
}

parse_args() {
    if [ $# -eq 0 ]; then
        if is_interactive_terminal; then
            action="interactive"
        else
            action="all"
        fi
        return 0
    fi

    action="$1"
    shift || true

    case "$action" in
        all|config)
            if [ $# -gt 0 ]; then
                config_url="$1"
                shift || true
            fi
            ;;
        set-url)
            [ $# -gt 0 ] || fail "Usage: sb set-url <url>"
            config_url="$1"
            shift || true
            ;;
        core|interactive|status|show-url|help) ;;
        *) fail "Unknown action: $action" ;;
    esac

    [ $# -eq 0 ] || fail "Too many arguments"
}

run_mutating_action() {
    require_root
    ensure_runtime_dirs
    mktemp_dir
    acquire_lock
    check_deps

    case "$action" in
        all|config) resolve_config_url >/dev/null ;;
    esac

    : > "$LOG_FILE"
    hr
    info "Task starting: $action"
    hr

    case "$action" in
        all)    update_core; update_config ;;
        core)   update_core ;;
        config) update_config ;;
    esac

    if [ "$core_changed" -eq 1 ] || [ "$config_changed" -eq 1 ]; then
        restart_service
    elif ! service_running; then
        warn "sing-box is not running, trying to start it..."
        restart_service
    else
        info "No restart needed."
    fi

    persist_config_snapshot

    if is_interactive_terminal; then
        show_result_panel
    fi
}

main() {
    setup_colors
    parse_args "$@"

    case "$action" in
        interactive)
            interactive_menu
            ;;
        status)
            show_status
            exit 0
            ;;
        show-url)
            show_url_cli
            exit 0
            ;;
        set-url)
            ensure_runtime_dirs
            require_root
            save_config_url "$config_url"
            exit 0
            ;;
        help)
            show_help
            exit 0
            ;;
    esac

    run_mutating_action
}

main "$@"
